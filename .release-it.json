{
  "src": {
    "addUntrackedFiles": true
  },
  "git": {
    "commitMessage": "chore(release): 🤖 v${version}",
    "requireBranch": "main",
    "requireCommits": false,
    "requireCleanWorkingDir": false,
    "tagName": "v${version}",
    "push": true
  },
  "github": {
    "release": true
  },
  "npm": { "publish": false },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "angular"
      },
      "infile": "CHANGELOG.md"
    }
  }
}
